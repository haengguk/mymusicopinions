# Railway backend service variables
# If your database service is not named "Postgres", replace the namespace below.
PGHOST=${{Postgres.PGHOST}}
PGPORT=${{Postgres.PGPORT}}
PGDATABASE=${{Postgres.PGDATABASE}}
PGUSER=${{Postgres.PGUSER}}
PGPASSWORD=${{Postgres.PGPASSWORD}}

JWT_SECRET_KEY=replace-with-a-base64-encoded-secret
YOUTUBE_API_KEY=
APP_SEED_ENABLED=false
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://*.vercel.app,https://*.up.railway.app,http://localhost:3000,http://localhost:5173,http://localhost:5175
